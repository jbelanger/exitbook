{
  "name": "@exitbook/data",
  "version": "0.1.0",
  "private": true,
  "description": "Data access layer for cryptocurrency platform",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./accounting": "./src/accounting.ts",
    "./balances": "./src/balances.ts",
    "./session": "./src/data-session.ts",
    "./ingestion": "./src/ingestion.ts",
    "./overrides": "./src/overrides.ts",
    "./projections": "./src/projections.ts",
    "./transaction-interpretation": "./src/transaction-interpretation.ts",
    "./test-utils": "./src/utils/test-utils.ts"
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc --noEmit",
    "clean": "rm -rf node_modules dist",
    "lint": "eslint \"src/**/*.ts\"",
    "prettier": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "test": "vitest run"
  },
  "dependencies": {
    "@exitbook/accounting": "workspace:*",
    "@exitbook/core": "workspace:*",
    "@exitbook/foundation": "workspace:*",
    "@exitbook/ingestion": "workspace:*",
    "@exitbook/logger": "workspace:*",
    "@exitbook/sqlite": "workspace:*",
    "@exitbook/transaction-interpretation": "workspace:*",
    "decimal.js": "^10.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "tsconfig": "workspace:*",
    "tsx": "^4.21.0"
  }
}
