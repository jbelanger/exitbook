{
  "name": "@exitbook/exchange-providers",
  "version": "0.1.0",
  "private": true,
  "description": "Exchange provider integrations using ccxt for raw data fetching",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./coinbase": "./src/exchanges/coinbase/index.ts",
    "./kraken": "./src/exchanges/kraken/index.ts",
    "./kucoin": "./src/exchanges/kucoin/index.ts"
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc --noEmit",
