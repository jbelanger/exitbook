{
  "name": "@exitbook/ingestion",
  "version": "0.1.0",
  "private": true,
  "description": "Cryptocurrency transaction ingestion package with multi-provider support",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./adapters": "./src/adapters.ts",
    "./asset-review": "./src/asset-review.ts",
    "./balance": "./src/balance.ts",
    "./events": "./src/events-entry.ts",
    "./import": "./src/import.ts",
    "./process": "./src/process.ts",
    "./ports": "./src/ports/index.ts"
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "scripts": {
    "build": "tsc --noEmit",
    "clean": "rm -rf node_modules dist",
    "exchanges:generate": "tsx src/scripts/generate-exchange-config.ts",
    "exchanges:list": "tsx src/scripts/list-exchange-adapters.ts",
    "exchanges:validate": "tsx src/scripts/validate-exchange-registry.ts",
    "exchanges:validate-config": "tsx src/scripts/validate-exchange-config.ts",
    "lint": "eslint \"src/**/*.ts\"",
    "prettier": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "test": "vitest run"
  },
  "dependencies": {
    "@exitbook/blockchain-providers": "workspace:*",
    "@exitbook/core": "workspace:*",
    "@exitbook/events": "workspace:*",
    "@exitbook/exchange-providers": "workspace:*",
    "@exitbook/foundation": "workspace:*",
    "@exitbook/ledger": "workspace:*",
    "@exitbook/logger": "workspace:*",
    "csv-parse": "^6.2.1",
    "decimal.js": "^10.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@exitbook/accounting": "workspace:*",
    "tsconfig": "workspace:*"
  }
}
