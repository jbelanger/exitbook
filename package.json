{
  "name": "exitbook",
  "version": "1.0.0",
  "private": true,
  "keywords": [
    "crypto",
    "transactions",
    "import"
  ],
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "blockchain-config:generate": "pnpm -F @exitbook/blockchain-providers blockchain-config:generate",
    "blockchain-config:validate": "pnpm -F @exitbook/blockchain-providers blockchain-config:validate",
    "blockchain-providers:list": "pnpm -F @exitbook/blockchain-providers blockchain-providers:list",
    "blockchain-providers:validate": "pnpm -F @exitbook/blockchain-providers blockchain-providers:validate",
    "build": "pnpm -r build",
    "clean": "pnpm -r run clean",
    "dev": "pnpm -F exitbook-cli dev",
    "lint": "pnpm -r run lint",
    "prepare": "husky",
    "prettier": "pnpm -r run prettier",
    "prettier:fix": "pnpm -r run prettier:fix",
    "providers:list": "pnpm -F @exitbook/blockchain-providers providers:list",
    "providers:sync": "pnpm -F @exitbook/blockchain-providers providers:sync",
    "providers:validate": "pnpm -F @exitbook/blockchain-providers providers:validate",
    "start": "pnpm -F exitbook-cli start",
    "test": "node --env-file-if-exists .env $(which pnpm) -r run test",
    "test:coverage": "node tools/run-vitest-coverage.mjs",
    "test:e2e": "node --env-file-if-exists .env node_modules/vitest/vitest.mjs run --config vitest.e2e.config.ts",
    "test:e2e:live": "LIVE_TESTS=1 node --env-file-if-exists .env node_modules/vitest/vitest.mjs run --config vitest.e2e.live.config.ts"
  },
  "lint-staged": {
    "*.{js,ts,tsx,json,md,yaml,yml}": [
      "prettier --write"
    ],
    "*.{js,ts,tsx}": [
      "eslint --fix"
    ]
  },
  "devDependencies": {
    "@eslint-community/eslint-plugin-eslint-comments": "^4.7.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "baseline-browser-mapping": "^2.10.20",
    "eslint": "^10.2.1",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-perfectionist": "^5.9.0",
    "eslint-plugin-unicorn": "^64.0.0",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "knip": "^6.5.0",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "prettier-plugin-packagejson": "^3.0.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.2",
    "vite": "8.0.9",
    "vitest": "^4.1.4"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.6.2"
  },
  "pnpm": {
    "overrides": {
      "ajv@<6.14.0": "6.14.0",
      "bn.js@<5.2.3": "5.2.3",
      "brace-expansion@<5.0.5": ">=5.0.5",
      "flatted@<=3.4.1": ">=3.4.2",
      "lodash@<4.18.1": "4.18.1",
      "minimatch@<10.2.3": "10.2.4",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "picomatch@<2.3.2": ">=2.3.2",
      "rollup@>=4.0.0 <4.59.0": "^4.59.0",
      "smol-toml@<1.6.1": ">=1.6.1",
      "yaml@>=2.0.0 <2.8.3": ">=2.8.3"
    }
  }
}
